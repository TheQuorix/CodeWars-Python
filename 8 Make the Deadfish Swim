def parse(data):
    numbers = []
    value = 0
    for char in data:
        if char == "i": value += 1
        elif char == "d": value -= 1
        elif char == "s": value *= value
        elif char == "o": numbers.append(value)
    return numbers

print(parse("iiisdoso"))
print(parse("iiisdosodddddiso"))
